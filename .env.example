# ===========================================
# TTE Tiered Orchestrator Configuration
# ===========================================

# Stock Buddy API
# Production: https://stock-buddy-app.vercel.app/api
# Development: http://localhost:3000/api
STOCK_BUDDY_API_URL=https://stock-buddy-app.vercel.app/api

# Chrome Configuration
# Path to Chrome user data directory (contains profiles)
# Windows: C:/Users/YourName/AppData/Local/Google/Chrome/User Data
# macOS: /Users/YourName/Library/Application Support/Google/Chrome
# Linux: /home/YourName/.config/google-chrome
CHROME_PROFILE_PATH=C:/Users/YourName/AppData/Local/Google/Chrome/User Data

# Chrome Profile Name (folder inside user data directory)
# Default is "Default", or "Profile 1", "Profile 2", etc.
CHROME_PROFILE_NAME=Default

# ===========================================
# TradingView Chart URLs
# ===========================================

# Saved layout URLs for each screener
# Create these layouts in TradingView and save them
NWE_CHART_URL=https://www.tradingview.com/chart/nwe_screener/
OBDIV_CHART_URL=https://www.tradingview.com/chart/obdiv_screener/

# ===========================================
# Logging Configuration
# ===========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=app_log.log

# ===========================================
# Batch Rotation Timing (seconds)
# ===========================================

# Time to wait after updating NWE screener symbols
# Allows bars to close and alerts to fire
NWE_BATCH_WAIT=120

# Time to wait after updating OBDIV screener symbols
OBDIV_BATCH_WAIT=30

# Time to wait before taking screenshot (page render)
SCREENSHOT_WAIT=3

# Polling interval for hot symbols and pending screenshots
POLL_INTERVAL=60

# ===========================================
# Batch Sizes
# ===========================================

# Number of symbols per NWE screener batch (max 20)
NWE_BATCH_SIZE=20

# Number of symbols per OBDIV screener batch (max 8)
OBDIV_BATCH_SIZE=8

# Number of screenshots to process per cycle
SCREENSHOT_BATCH_SIZE=5

# ===========================================
# Selenium Timeouts (seconds)
# ===========================================

# Implicit wait for element presence
SELENIUM_IMPLICIT_WAIT=10

# Explicit wait for specific conditions
SELENIUM_EXPLICIT_WAIT=30

# Page load timeout
PAGE_LOAD_TIMEOUT=60

# ===========================================
# Retry Configuration
# ===========================================

# Maximum number of retries for API calls
MAX_RETRIES=3

# Base delay between retries (uses exponential backoff)
RETRY_DELAY=5

# ===========================================
# Legacy Configuration (from existing system)
# Keep these for backward compatibility
# ===========================================

# Twitter API credentials
X_API_KEY=
X_API_SECRET=
X_BEARER=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

# Discord webhook names and links
CURRENCIES_WEBHOOK_NAME=
US_STOCKS_WEBHOOK_NAME=
INDIAN_STOCKS_WEBHOOK_NAME=
CRYPTO_WEBHOOK_NAME=

CURRENCIES_ENTRY_WEBHOOK_LINK=
US_STOCKS_ENTRY_WEBHOOK_LINK=
INDIAN_STOCKS_ENTRY_WEBHOOK_LINK=
CRYPTO_ENTRY_WEBHOOK_LINK=

CURRENCIES_EXIT_WEBHOOK_LINK=
US_STOCKS_EXIT_WEBHOOK_LINK=
INDIAN_STOCKS_EXIT_WEBHOOK_LINK=
CRYPTO_EXIT_WEBHOOK_LINK=

CURRENCIES_BEFORE_AFTER_WEBHOOK_LINK=
US_STOCKS_BEFORE_AFTER_WEBHOOK_LINK=
INDIAN_STOCKS_BEFORE_AFTER_WEBHOOK_LINK=
CRYPTO_BEFORE_AFTER_WEBHOOK_LINK=
