{
  "permissions": {
    "env": {
      "CLAUDE_CODE_TASK_LIST_ID": "tte"
    },
    "deny": [
        "Read(./.env)",
        "Read(./.env.*)",
        "Read(./secrets/**)",
        "Read(./config/credentials.json)",
        "Read(./**/*.pem)",
        "Read(./**/*.key)",
        "Read(./**/private*)",
        "Read(./build)",
        "Write(./.claude/settings.json)",
        "Edit(./.claude/settings.json)",

        "Bash(git push --force:*)",
        "Bash(git push -f:*)",
        "Bash(git reset --hard:*)",
        "Bash(git clean -fd:*)",
        "Bash(git clean -f:*)",
        "Bash(git checkout -- .:*)",
        "Bash(git stash drop:*)",
        "Bash(git stash clear:*)",
        "Bash(git rebase:*)",
        "Bash(git branch -D:*)",
        "Bash(git tag -d:*)",
        "Bash(git push --delete:*)",
        "Bash(git push origin --delete:*)",
        "Bash(git filter-branch:*)",
        "Bash(git push origin ::*)",
        "Bash(git reflog expire:*)",
        "Bash(git gc --prune=now:*)",

        "Bash(rm -rf:*)",
        "Bash(rm -fr:*)",
        "Bash(rm -r:*)",
        "Bash(rm *.db:*)",
        "Bash(rm */*.db:*)",
        "Bash(rm **/*.db:*)",
        "Bash(del /s:*)",
        "Bash(del /q:*)",
        "Bash(rmdir /s:*)",
        "Bash(rmdir /q:*)",
        "Bash(truncate:*)",
        "Bash(shred:*)",
        "Bash(> :*)",

        "Bash(gh repo delete:*)",
        "Bash(gh release delete:*)",

        "Bash(DROP DATABASE:*)",
        "Bash(DROP TABLE:*)",
        "Bash(TRUNCATE TABLE:*)",
        "Bash(mongo*dropDatabase:*)",
        "Bash(mongo*dropCollection:*)",
        "Bash(redis-cli FLUSHALL:*)",
        "Bash(redis-cli FLUSHDB:*)",
        "Bash(psql*DROP:*)",

        "Bash(docker system prune -a:*)",
        "Bash(docker rm -f:*)",
        "Bash(docker rmi -f:*)",
        "Bash(docker volume rm:*)",
        "Bash(docker container prune -f:*)",

        "Bash(mkfs:*)",
        "Bash(dd if=/dev/zero:*)",
        "Bash(dd of=/:*)",
        "Bash(wipefs:*)",
        "Bash(fdisk:*)",
        "Bash(parted:*)",

        "Bash(chmod 777:*)",
        "Bash(chmod -R 777:*)",
        "Bash(chmod 000:*)",
        "Bash(chmod -R 000:*)",
        "Bash(chown -R root:*)",

        "Bash(shutdown:*)",
        "Bash(reboot:*)",
        "Bash(init 0:*)",
        "Bash(init 6:*)",
        "Bash(kill -9 -1:*)",
        "Bash(killall:*)",
        "Bash(pkill -9:*)",

        "Bash(aws s3 rm --recursive:*)",
        "Bash(aws s3 rb --force:*)",
        "Bash(aws ec2 terminate-instances:*)",
        "Bash(gcloud compute instances delete:*)",
        "Bash(az vm delete:*)",
        "Bash(az group delete:*)",

        "Bash(npm cache clean --force:*)",
        "Bash(pip uninstall -y -r:*)",
        "Bash(pip freeze | xargs pip uninstall:*)",

        "Bash(cat ~/.ssh/id_rsa:*)",
        "Bash(cat ~/.ssh/id_ed25519:*)",
        "Bash(printenv:*)",
        "Bash(env | grep:*)",
        "Bash(export *=:*)",

        "Bash(mv /* :*)",
        "Bash(mv / :*)",
        "Bash(> /dev/sda:*)",
        "Bash(curl*| bash:*)",
        "Bash(wget*| bash:*)",
        "Bash(curl*| sh:*)",
        "Bash(wget*| sh:*)",

        "mcp__task-master-ai__initialize_task_master"
      ]
  },
  "hooks": {
    "PreToolUse": [],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/notify-response.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/update-task-context.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cat .claude/task-context.md"
          }
        ]
      }
    ]
  },
  "outputStyle": "default"
}
