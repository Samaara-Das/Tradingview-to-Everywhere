# =============================================================================
# TTE Orchestrator - Production Environment Configuration
# =============================================================================
# Updated: 2026-01-29

# -----------------------------------------------------------------------------
# Stock Buddy API (PRODUCTION - Vercel)
# -----------------------------------------------------------------------------
STOCK_BUDDY_API_URL=https://stock-buddy-app.vercel.app/api/tte

# -----------------------------------------------------------------------------
# Chrome Configuration
# -----------------------------------------------------------------------------
# Path to Chrome user data directory (for persistent TradingView sessions)
CHROME_PROFILE_PATH=C:/Users/dassa/AppData/Local/Google/Chrome/User Data
CHROME_PROFILE_NAME=Default

# -----------------------------------------------------------------------------
# TradingView Configuration
# -----------------------------------------------------------------------------
# Your saved TradingView chart URLs with the screeners loaded
# ⚠️ UPDATE THESE with your actual chart URLs!

NWE_CHART_URL=https://in.tradingview.com/chart/VCj8tuCO/
OBDIV_CHART_URL=https://in.tradingview.com/chart/pkAAqc5i/

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/orchestrator.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# -----------------------------------------------------------------------------
# Batch Processing Configuration (seconds)
# -----------------------------------------------------------------------------
NWE_BATCH_WAIT=120       # Wait after updating NWE symbols for scan
OBDIV_BATCH_WAIT=30      # Wait after updating OBDIV symbols for scan
SCREENSHOT_WAIT=3        # Wait before taking screenshot
POLL_INTERVAL=60         # Wait between cycles

# -----------------------------------------------------------------------------
# Batch Sizes
# -----------------------------------------------------------------------------
NWE_BATCH_SIZE=20        # Symbols per NWE batch (max 20)
OBDIV_BATCH_SIZE=8       # Symbols per OBDIV batch (max 8)
SCREENSHOT_BATCH_SIZE=5  # Screenshots per cycle

# -----------------------------------------------------------------------------
# Selenium Timeouts (seconds)
# -----------------------------------------------------------------------------
SELENIUM_IMPLICIT_WAIT=10
SELENIUM_EXPLICIT_WAIT=30
PAGE_LOAD_TIMEOUT=60
SCRIPT_TIMEOUT=30

# -----------------------------------------------------------------------------
# Retry Configuration
# -----------------------------------------------------------------------------
MAX_RETRIES=3
RETRY_DELAY=5
RETRY_BACKOFF=2

# -----------------------------------------------------------------------------
# Screenshot Configuration
# -----------------------------------------------------------------------------
SCREENSHOT_DIR=screenshots
SCREENSHOT_FORMAT=png
SCREENSHOT_QUALITY=90
UPLOAD_SCREENSHOTS=false

# -----------------------------------------------------------------------------
# Error Handling
# -----------------------------------------------------------------------------
CONTINUE_ON_ERROR=true
ERROR_NOTIFICATIONS=false
SCREENSHOT_ON_ERROR=true

# -----------------------------------------------------------------------------
# Debug Mode
# -----------------------------------------------------------------------------
DEBUG_MODE=false
HEADLESS=false
